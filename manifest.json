{
  "manifest_version": 3,
  "name": "FC26 SBC Helper",
  "version": "1.0.0",
  "description": "SBC最低成本阵容计算 - 一键自动填阵",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FC26 SBC Helper"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["vue-inject.js"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "128": "icon.png"
  }
}
